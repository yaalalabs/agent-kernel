{
  "skill": "ak-add-integration",
  "description": "Evaluations for the ak-add-integration (messaging platform) skill",
  "version": "0.5.0",
  "evals": [
    {
      "id": "int-slack",
      "name": "Add Slack integration",
      "input": "Add Slack integration to my Agent Kernel project",
      "expected_outputs": [
        "agentkernel[", "slack",
        "AgentSlackRequestHandler",
        "RESTAPI.run([",
        "SLACK_BOT_TOKEN",
        "SLACK_SIGNING_SECRET",
        "slack:",
        "config.yaml"
      ],
      "must_not_contain": [
        "AgentWhatsAppRequestHandler",
        "AgentTelegramRequestHandler"
      ]
    },
    {
      "id": "int-whatsapp",
      "name": "Add WhatsApp integration",
      "input": "Add WhatsApp integration to my project",
      "expected_outputs": [
        "agentkernel[", "whatsapp",
        "AgentWhatsAppRequestHandler",
        "AK_WHATSAPP__ACCESS_TOKEN",
        "AK_WHATSAPP__PHONE_NUMBER_ID",
        "whatsapp:",
        "verify_token"
      ]
    },
    {
      "id": "int-messenger",
      "name": "Add Facebook Messenger integration",
      "input": "Add Messenger integration",
      "expected_outputs": [
        "agentkernel[", "messenger",
        "AgentMessengerRequestHandler",
        "AK_MESSENGER__ACCESS_TOKEN"
      ]
    },
    {
      "id": "int-instagram",
      "name": "Add Instagram integration",
      "input": "Add Instagram integration",
      "expected_outputs": [
        "agentkernel[", "instagram",
        "AgentInstagramRequestHandler",
        "AK_INSTAGRAM__ACCESS_TOKEN"
      ]
    },
    {
      "id": "int-telegram",
      "name": "Add Telegram integration",
      "input": "Add Telegram integration",
      "expected_outputs": [
        "agentkernel[", "telegram",
        "AgentTelegramRequestHandler",
        "AK_TELEGRAM__BOT_TOKEN"
      ]
    },
    {
      "id": "int-gmail",
      "name": "Add Gmail integration",
      "input": "Add Gmail integration",
      "expected_outputs": [
        "agentkernel[", "gmail",
        "AgentGmailRequestHandler",
        "gmail:",
        "poll_interval",
        "token_file"
      ]
    },
    {
      "id": "int-teams",
      "name": "Add Teams integration",
      "input": "Add Microsoft Teams integration",
      "expected_outputs": [
        "agentkernel[", "teams",
        "AgentTeamsRequestHandler",
        "AK_TEAMS__APP_ID",
        "AK_TEAMS__APP_PASSWORD",
        "teams:",
        "agent_acknowledgement"
      ]
    },
    {
      "id": "int-multiple",
      "name": "Add multiple integrations",
      "input": "Add both Slack and WhatsApp integrations to my project",
      "expected_outputs": [
        "RESTAPI.run([",
        "AgentSlackRequestHandler()",
        "AgentWhatsAppRequestHandler()",
        "agentkernel[", "slack", "whatsapp"
      ]
    },
    {
      "id": "int-no-project",
      "name": "No project found fallback",
      "input": "Add Slack to my project (no pyproject.toml exists)",
      "expected_outputs": [
        "ak-init"
      ],
      "description": "Should suggest using ak-init skill when no project is found"
    }
  ]
}
