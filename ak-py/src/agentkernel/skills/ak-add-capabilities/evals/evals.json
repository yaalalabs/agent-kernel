{
  "skill": "ak-add-capabilities",
  "description": "Evaluations for the ak-add-capabilities (guardrails, tracing, sessions, MCP, A2A, hooks, multimodal) skill",
  "version": "0.2.13",
  "evals": [
    {
      "id": "cap-guardrail-openai",
      "name": "Add OpenAI guardrails",
      "input": "Add OpenAI input guardrails to my project",
      "expected_outputs": [
        "guardrail:",
        "type: openai",
        "config_path:",
        "agentkernel[",
        "config.yaml"
      ],
      "must_not_contain": [
        "type: bedrock",
        "type: walledai"
      ]
    },
    {
      "id": "cap-guardrail-bedrock",
      "name": "Add Bedrock guardrails",
      "input": "Add AWS Bedrock guardrails to my project",
      "expected_outputs": [
        "guardrail:",
        "type: bedrock",
        "guardrail_id:",
        "guardrail_version:"
      ]
    },
    {
      "id": "cap-guardrail-walledai",
      "name": "Add Walled AI guardrails",
      "input": "Add Walled AI guardrails to my project",
      "expected_outputs": [
        "guardrail:",
        "type: walledai",
        "WALLED_API_KEY",
        "pii:"
      ]
    },
    {
      "id": "cap-tracing-langfuse",
      "name": "Add Langfuse tracing",
      "input": "Add Langfuse tracing to my project",
      "expected_outputs": [
        "trace:",
        "type: langfuse",
        "enabled: true",
        "LANGFUSE_PUBLIC_KEY",
        "LANGFUSE_SECRET_KEY",
        "agentkernel[", "langfuse"
      ],
      "must_not_contain": [
        "type: openllmetry"
      ]
    },
    {
      "id": "cap-tracing-openllmetry",
      "name": "Add OpenLLMetry tracing",
      "input": "Add OpenLLMetry tracing to my project",
      "expected_outputs": [
        "trace:",
        "type: openllmetry",
        "enabled: true",
        "agentkernel[", "openllmetry"
      ]
    },
    {
      "id": "cap-session-redis",
      "name": "Add Redis session persistence",
      "input": "Add Redis session persistence to my project",
      "expected_outputs": [
        "session:",
        "type: redis",
        "redis:",
        "prefix:",
        "url:",
        "agentkernel[", "redis"
      ]
    },
    {
      "id": "cap-session-dynamodb",
      "name": "Add DynamoDB session persistence",
      "input": "Add DynamoDB session persistence",
      "expected_outputs": [
        "session:",
        "type: dynamodb",
        "table_name:",
        "region:",
        "agentkernel[", "aws"
      ]
    },
    {
      "id": "cap-session-cosmosdb",
      "name": "Add Cosmos DB session persistence",
      "input": "Add Cosmos DB session persistence",
      "expected_outputs": [
        "session:",
        "type: cosmosdb",
        "endpoint:",
        "AZURE_COSMOS_KEY",
        "agentkernel[", "azure"
      ]
    },
    {
      "id": "cap-mcp",
      "name": "Enable MCP server",
      "input": "Expose my agents as MCP tools",
      "expected_outputs": [
        "mcp:",
        "enabled: true",
        "expose_agents:",
        "agentkernel[", "mcp"
      ]
    },
    {
      "id": "cap-a2a",
      "name": "Enable A2A server",
      "input": "Enable Agent-to-Agent communication via A2A",
      "expected_outputs": [
        "a2a:",
        "enabled: true",
        "agents:",
        "agentkernel[", "a2a",
        ".well-known/agent.json"
      ]
    },
    {
      "id": "cap-hooks-pre",
      "name": "Add pre-hook",
      "input": "Add a RAG pre-hook to my agent",
      "expected_outputs": [
        "class ", "PreHook",
        "async def on_run(",
        "session: Session",
        "requests: list[AgentRequest]",
        "module.pre_hook("
      ]
    },
    {
      "id": "cap-hooks-post",
      "name": "Add post-hook",
      "input": "Add a disclaimer post-hook to my agent",
      "expected_outputs": [
        "class ", "PostHook",
        "async def on_run(",
        "agent_reply: AgentReply",
        "module.post_hook("
      ]
    },
    {
      "id": "cap-multimodal",
      "name": "Enable multimodal support",
      "input": "Enable image and file processing",
      "expected_outputs": [
        "multimodal:",
        "enabled: true",
        "description_model:",
        "analysis_model:"
      ]
    }
  ]
}
