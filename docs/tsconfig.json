{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "types": ["node", "@docusaurus/module-type-aliases"]
  },
  "include": ["src/**/*", "docusaurus.config.js", "sidebars.js", "**/*.d.ts"],
  "exclude": ["node_modules", "build", ".docusaurus"]
}