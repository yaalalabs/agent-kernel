      "name": "Scaffold CrewAI CLI project",
      "input": "Create a new Agent Kernel project using CrewAI with CLI mode",
      "expected_outputs": [
        "from agentkernel.crewai import CrewAIModule",
        "from agentkernel.crewai import CrewAIToolBuilder",
        "from crewai import Agent",
        "role=",
        "verbose=False",
        "CrewAIModule(["
      ],
      "must_not_contain": [
