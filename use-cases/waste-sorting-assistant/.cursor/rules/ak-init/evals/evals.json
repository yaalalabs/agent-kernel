    },
    {
      "id": "init-openai-lambda",
      "name": "Scaffold OpenAI AWS Lambda project",
      "input": "Create a new Agent Kernel project using OpenAI with AWS Lambda deployment",
      "expected_outputs": [
        "from agentkernel.aws import Lambda",
        "handler = Lambda.handler",
        "deploy/main.tf",
        "deploy/Dockerfile"
      ],
      "expected_files": [
        "lambda.py",
        "config.yaml",
        "deploy/main.tf",
        "deploy/variables.tf",
        "deploy/deploy.sh",
        "deploy/Dockerfile"
      ]
    },
    {
      "id": "init-config-yaml",
      "name": "Generate valid config.yaml",
      "input": "Create a new Agent Kernel project",
      "expected_outputs": [
        "session:",
        "type: in_memory"
      ],
      "must_not_contain": [
        "type: redis"
      ]
    },
    {
      "id": "init-pyproject-toml",
      "name": "Generate valid pyproject.toml",
      "input": "Create a new Agent Kernel project",
