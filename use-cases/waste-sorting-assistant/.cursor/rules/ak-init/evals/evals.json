{
  "skill": "ak-init",
  "description": "Evaluations for the ak-init (project scaffolding) skill",
  "version": "0.6.0",
  "evals": [
    {
      "id": "init-openai-cli",
      "name": "Scaffold OpenAI CLI project",
      "input": "Create a new Agent Kernel project using OpenAI Agents SDK with CLI mode",
      "expected_outputs": [
        "from agentkernel.openai import OpenAIModule",
        "from agentkernel.openai import OpenAIToolBuilder",
        "from agents import Agent",
        "OpenAIModule([",
        "agentkernel[openai]",
        "config.yaml",
        "pyproject.toml"
      ],
      "expected_files": [
        "demo.py",
        "tool.py",
        "config.yaml",
        "pyproject.toml",
        "build.sh",
        "demo_test.py"
      ],
      "must_not_contain": [
        "RESTAPI",
        "Lambda.handler",
        "AzureFunction"
      ]
    },
    {
      "id": "init-openai-api",
      "name": "Scaffold OpenAI API project",
      "input": "Create a new Agent Kernel project using OpenAI Agents SDK with REST API mode",
      "expected_outputs": [
        "from agentkernel.api import RESTAPI",
        "from agentkernel.openai import OpenAIModule",
        "RESTAPI.run()",
        "agentkernel[openai,api]"
      ],
      "expected_files": [
        "app.py",
        "tool.py",
        "config.yaml",
        "pyproject.toml"
      ]
    },
    {
