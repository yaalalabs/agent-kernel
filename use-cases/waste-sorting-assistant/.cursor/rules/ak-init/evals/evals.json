      "input": "Create a new Agent Kernel project using Google ADK with CLI mode",
      "expected_outputs": [
        "from agentkernel.adk import GoogleADKModule",
        "from agentkernel.adk import GoogleADKToolBuilder",
        "from google.adk.agents import Agent",
        "LiteLlm(model=",
        "GoogleADKModule(["
      ],
      "must_not_contain": [
        "OpenAIModule",
        "crewai"
      ]
    },
    {
      "id": "init-smolagents-cli",
      "name": "Scaffold Smolagents CLI project",
      "input": "Create a new Agent Kernel project using Smolagents with CLI mode",
      "expected_outputs": [
        "from agentkernel.smolagents import SmolagentsModule",
        "from agentkernel.smolagents import SmolagentsToolBuilder",
        "from smolagents import LiteLLMModel, ToolCallingAgent",
        "SmolagentsModule(["
