        "from agentkernel.langgraph import LangGraphToolBuilder",
        "from langgraph.prebuilt import create_react_agent",
        "name=",
        "LangGraphModule(["
      ],
      "must_not_contain": [
        "OpenAIModule",
        "CrewAIModule"
      ]
    },
    {
